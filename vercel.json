{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/proxy$",
      "dest": "/api/proxy.js"
    },
    {
      "src": "/api/v2/(.*)",
      "dest": "/api/proxy.js?path=$1"
    },
    {
      "src": "/(.*)",
      "status": 404
    }
  ]
}
